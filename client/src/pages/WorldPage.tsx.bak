import { useState, useEffect, useCallback } from 'react';
import { useParams, useNavigate } from 'react-router-dom';
import { motion, AnimatePresence } from 'framer-motion';
import { useStore } from '../store';
import { IsometricMap } from '../components/world/IsometricMap';
import { ArrowLeft, Heart, Package, Hammer, ScrollText, TrendingUp, Map, Sparkles, Loader2, Globe, TreePine, Mountain, Waves, CloudSnow, Droplets } from 'lucide-react';

interface Tile { id: string; x: number; y: number; terrain: string; elevation: number; resource_type: string | null; resource_amount: number; building_id: string | null; }
interface Building { id: string; tile_x: number; tile_y: number; building_type: string; name: string; health: number; level: number; }
interface NPC { id: string; name: string; personality: string; type: string; x: number; y: number; is_unique: boolean; }
interface InvItem { id: string; item_type: string; quantity: number; slot: number; }
interface Quest { id: string; title: string; description: string; objective_type: string; status: string; reward: any; }

const BIOMES = [
  { id: 'mixed', label: 'Смешанный', icon: Globe, desc: 'Леса, равнины, горы' },
  { id: 'forest', label: 'Лесной', icon: TreePine, desc: 'Густые леса и чащи' },
  { id: 'desert', label: 'Пустыня', icon: Globe, desc: 'Пески и скалы' },
  { id: 'snow', label: 'Снежный', icon: CloudSnow, desc: 'Вечная мерзлота' },
  { id: 'swamp', label: 'Болотный', icon: Droplets, desc: 'Топи и трясины' },
  { id: 'plains', label: 'Равнины', icon: Map, desc: 'Открытые пространства' },
  { id: 'mountain', label: 'Горный', icon: Mountain, desc: 'Скалы и хребты' },
];

export function WorldPage() {
  const { roomId } = useParams<{ roomId: string }>();
  const { socket, user } = useStore();
  const navigate = useNavigate();
  const [activeTab, setActiveTab] = useState<'map' | 'inventory' | 'quests' | 'build'>('map');
  const [tiles, setTiles] = useState<Tile[]>([]);
  const [buildings, setBuildings] = useState<Building[]>([]);
  const [npcs, setNpcs] = useState<NPC[]>([]);
  const [inventory, setInventory] = useState<InvItem[]>([]);
  const [quests, setQuests] = useState<Quest[]>([]);
  const [playerPos, setPlayerPos] = useState({ x: 250, y: 250 });
  const [worldState, setWorldState] = useState<any>(null);
  const [aiEvent, setAiEvent] = useState<any>(null);
  const [buildingMode, setBuildingMode] = useState(false);
  const [selectedBuilding, setSelectedBuilding] = useState('house');
  const [loading, setLoading] = useState(true);
  const [generating, setGenerating] = useState(false);
  // Config wizard
  const [showConfig, setShowConfig] = useState(false);
  const [cfgBiome, setCfgBiome] = useState('mixed');
  const [cfgDensity, setCfgDensity] = useState('medium');
  const [cfgDifficulty, setCfgDifficulty] = useState('normal');
  const [cfgPrompt, setCfgPrompt] = useState('');
  const [genError, setGenError] = useState('');
  const [genStats, setGenStats] = useState<any>(null);
  const [mapSeed, setMapSeed] = useState(0);
  const [mapBiome, setMapBiome] = useState('mixed');
  const [mapDensity, setMapDensity] = useState(1.0);
  const [tiles, setTiles] = useState<Tile[]>([]);

  const hdrs = { Authorization: `Bearer ${localStorage.getItem('demiurge_token') || ''}` };

  const loadWorld = () => {
    if (!roomId) return;
    setLoading(true);
    fetch(`/api/world/${roomId}`, { headers: hdrs }).then(r => r.json()).then(ws => {
      setWorldState(ws);
      setMapSeed(ws.seed || 0);
      if (!ws.width || ws.width < 100) {
        fetch(`/api/world/${roomId}`, { method: 'PATCH', headers: { 'Content-Type': 'application/json', ...hdrs }, body: JSON.stringify({ width: 500, height: 500 }) }).catch(() => {});
      }
    }).catch(() => {});
    fetch(`/api/world/${roomId}/buildings`, { headers: hdrs }).then(r => r.json()).then(setBuildings).catch(() => {});
    fetch(`/api/world/${roomId}/npcs`, { headers: hdrs }).then(r => r.json()).then(setNpcs).catch(() => {});
    fetch(`/api/world/${roomId}/inventory`, { headers: hdrs }).then(r => r.json()).then(setInventory).catch(() => {});
    fetch(`/api/world/${roomId}/quests`, { headers: hdrs }).then(r => r.json()).then(setQuests).catch(() => {});
    setLoading(false);
  };
  };

  useEffect(() => { loadWorld(); }, [roomId]);

  useEffect(() => {
    if (!socket || !roomId) return;
    socket.emit('room:join', roomId);
    socket.on('world:player_moved', () => {});
    socket.on('world:resource_gathered', (d: any) => {
      if (d.userId === user?.id) setInventory(prev => { const ex = prev.find(i => i.item_type === d.resourceType); if (ex) return prev.map(i => i.item_type === d.resourceType ? { ...i, quantity: i.quantity + 1 } : i); return [...prev, { id: '', item_type: d.resourceType, quantity: 1, slot: prev.length }]; });
    });
    socket.on('world:event', (e: any) => { setAiEvent(e); setTimeout(() => setAiEvent(null), 10000); });
    return () => { socket.emit('room:leave', roomId); socket.off('world:player_moved'); socket.off('world:resource_gathered'); socket.off('world:event'); };
  }, [socket, roomId]);

  const generateWorld = async () => {
    if (!roomId) return;
    setGenerating(true); setGenError('');
    try {
    const densityVal = cfgDensity === 'high' ? 1.5 : cfgDensity === 'low' ? 0.5 : 1.0;
    setMapBiome(cfgBiome);
    setMapDensity(densityVal);
    setShowConfig(false);
    setGenerating(false);
    setGenStats({ tiles: '∞', buildings: 0, npcs: 0, factions: 0, quests: 0 });
    setTimeout(() => setGenStats(null), 3000);
    } catch (e: any) { setGenError('Ошибка'); setGenerating(false); }
  };

  const handleTileClick = (tx: number, ty: number) => {
    if (buildingMode) { setBuildingMode(false); return; }
    setPlayerPos({ x: tx, y: ty });
    if (socket && roomId) socket.emit('world:move', { roomId, x: tx, y: ty });
  };
  const handleGather = () => { if (socket && roomId) socket.emit('world:gather', { roomId, tileX: playerPos.x, tileY: playerPos.y }); };
  const handleBuild = async () => {
    if (!roomId) return;
    const res = await fetch(`/api/world/${roomId}/buildings`, { method: 'POST', headers: { 'Content-Type': 'application/json', ...hdrs }, body: JSON.stringify({ tileX: playerPos.x, tileY: playerPos.y, buildingType: selectedBuilding, name: selectedBuilding }) });
    if (res.ok) { const b = await res.json(); setBuildings(prev => [...prev, b]); setBuildingMode(false); }
  };
  const requestEvent = () => { if (socket && roomId) socket.emit('world:request_events', { roomId }); };

  const terrainColors: Record<string, string> = {
    grass: '#4ade80', forest: '#166534', deep_forest: '#14532d', plains: '#84cc16', desert: '#f59e0b', sand_dunes: '#d97706',
    snow: '#e0f2fe', tundra: '#bae6fd', swamp: '#4a7c59', water: '#3b82f6', river: '#60a5fa', lake: '#2563eb',
    mountain: '#78716c', rocky: '#a8a29e', volcano: '#ef4444', wasteland: '#57534e',
    crystal: '#c084fc', enchanted: '#a78bfa', corrupted: '#7c3aed',
    cavern_entrance: '#292524', dungeon_entrance: '#1c1917',
  };

  return (
    <div className="h-full flex flex-col bg-[#0d0d14]">
      {/* Config Wizard */}
      <AnimatePresence>
        {showConfig && (
          <motion.div initial={{ opacity: 0 }} animate={{ opacity: 1 }} exit={{ opacity: 0 }} className="fixed inset-0 z-50 flex items-center justify-center bg-black/70 backdrop-blur-md">
            <motion.div initial={{ scale: 0.9 }} animate={{ scale: 1 }} className="bg-[#0f0f16] border border-[#1a1a2e] rounded-2xl p-8 w-[600px] max-h-[85vh] overflow-y-auto shadow-2xl">
              <h2 className="font-mono text-xl text-zinc-200 mb-1 flex items-center gap-2"><Sparkles size={22} className="text-blue-400" /> Создание мира</h2>
              <p className="font-mono text-xs text-zinc-500 mb-6">AI сгенерирует карту с ландшафтом, ресурсами, NPC, зданиями и квестами</p>

              <div className="space-y-5">
                <div>
                  <label className="text-[10px] font-mono text-zinc-500 uppercase tracking-wider mb-2 block">Биом</label>
                  <div className="grid grid-cols-4 gap-2">
                    {BIOMES.map(b => (
                      <button key={b.id} onClick={() => setCfgBiome(b.id)} className={`p-2.5 rounded-xl border text-center transition-all ${cfgBiome===b.id?'border-blue-500 bg-blue-600/20':'border-[#1a1a2e] hover:border-zinc-600'}`}>
                        <b.icon size={18} className={`mx-auto mb-1 ${cfgBiome===b.id?'text-blue-400':'text-zinc-500'}`} /><div className="font-mono text-[10px] text-zinc-300">{b.label}</div>
                      </button>
                    ))}
                  </div>
                </div>
                <div className="grid grid-cols-2 gap-4">
                  <div><label className="text-[10px] font-mono text-zinc-500 mb-1.5 block">Плотность</label><div className="flex rounded-lg overflow-hidden border border-[#1a1a2e]">{['low','medium','high'].map(d=><button key={d} onClick={()=>setCfgDensity(d)} className={`flex-1 py-1.5 text-[10px] font-mono ${cfgDensity===d?'bg-blue-600/20 text-blue-400':'text-zinc-500'}`}>{d==='low'?'Низкая':d==='medium'?'Средняя':'Высокая'}</button>)}</div></div>
                  <div><label className="text-[10px] font-mono text-zinc-500 mb-1.5 block">Сложность</label><div className="flex rounded-lg overflow-hidden border border-[#1a1a2e]">{['easy','normal','hard'].map(d=><button key={d} onClick={()=>setCfgDifficulty(d)} className={`flex-1 py-1.5 text-[10px] font-mono ${cfgDifficulty===d?'bg-blue-600/20 text-blue-400':'text-zinc-500'}`}>{d==='easy'?'Лёгкая':d==='normal'?'Норм':'Хард'}</button>)}</div></div>
                </div>
                <div>
                  <label className="text-[10px] font-mono text-zinc-500 mb-1.5 block">Промпт для AI (пожелания)</label>
                  <textarea value={cfgPrompt} onChange={e=>setCfgPrompt(e.target.value)} className="input-field resize-none h-20 text-xs" placeholder="Опиши какой мир хочешь: мрачное подземелье с драконами, волшебный лес с эльфами..." />
                  {genError && <div className="p-3 rounded-lg bg-red-500/10 border border-red-500/30 text-red-400 font-mono text-xs">{genError}</div>}
                </div>
                <div className="flex gap-2">
                  <button onClick={generateWorld} disabled={generating} className="flex-1 py-3 rounded-xl font-mono text-sm font-bold bg-gradient-to-r from-blue-600 to-purple-600 text-white hover:opacity-90 disabled:opacity-60 transition-all flex items-center justify-center gap-2">{generating?<><Loader2 size={18} className="animate-spin"/>Генерация...</>:<><Sparkles size={18}/>Сгенерировать мир</>}</button>
                  <button onClick={()=>setShowConfig(false)} className="px-4 py-3 rounded-xl border border-[#1a1a2e] font-mono text-sm text-zinc-400 hover:bg-white/5">Пропустить</button>
                </div>
              </div>
            </motion.div>
          </motion.div>
        )}
      </AnimatePresence>

      {/* Top bar */}
      <div className="h-12 bg-[#111118] border-b border-[#1a1a2e] flex items-center px-4 gap-3 shrink-0 z-20">
        <a href="/" className="p-1.5 rounded-md hover:bg-white/5 text-zinc-400"><ArrowLeft size={18} /></a>
        <div className="flex-1 flex items-center gap-3">
          <h2 className="font-mono text-sm text-zinc-300">{worldState ? `Мир #${worldState.seed}` : 'Загрузка...'}</h2>
          {worldState && <span className={`text-[10px] font-mono px-2 py-0.5 rounded ${worldState.ai_god_personality === 'kind' ? 'bg-emerald-500/20 text-emerald-400' : worldState.ai_god_personality === 'evil' ? 'bg-red-500/20 text-red-400' : 'bg-purple-500/20 text-purple-400'}`}>Бог: {worldState.ai_god_personality}</span>}
        </div>
        <div className="flex items-center gap-2"><Heart size={14} className="text-red-400" /><div className="w-16 h-2 bg-[#1a1a2e] rounded-full overflow-hidden"><div className="h-full bg-red-500" style={{ width: '100%' }} /></div></div>
        <button onClick={() => setShowConfig(true)} className="text-[10px] font-mono text-blue-400 hover:underline">Настроить</button>
        <button onClick={requestEvent} className="btn-secondary text-[10px] py-1 px-2">⚡ Событие</button>
      </div>

      {genStats && (
        <motion.div initial={{ opacity: 0, height: 0 }} animate={{ opacity: 1, height: 'auto' }} className="bg-emerald-500/10 border-b border-emerald-500/20 px-4 py-2">
          <p className="font-mono text-xs text-emerald-400">✅ Мир создан! {genStats.tiles} тайлов, {genStats.buildings} зданий, {genStats.npcs} NPC, {genStats.factions} фракций, {genStats.quests} квестов</p>
        </motion.div>
      )}
      {aiEvent && (
        <motion.div initial={{ opacity: 0, height: 0 }} animate={{ opacity: 1, height: 'auto' }} className="bg-blue-500/10 border-b border-blue-500/20 px-4 py-2">
          <p className="font-mono text-xs text-blue-400">⚡ {aiEvent.eventType?.toUpperCase()}: {aiEvent.description}</p>
        </motion.div>
      )}

        <div className="flex-1 flex overflow-hidden">
          <div className="flex-1 relative">
          {!showConfig && (
          <IsometricMap buildings={buildings} npcs={npcs} playerPos={playerPos} buildingMode={buildingMode} onTileClick={handleTileClick} onGather={handleGather} onBuild={handleBuild} terrainColors={terrainColors} seed={mapSeed} biome={mapBiome} density={mapDensity} />
          )}
            <div className="absolute top-3 left-3 glass-panel px-3 py-1.5 font-mono text-[10px] text-zinc-400">X: {playerPos.x} · Y: {playerPos.y}</div>
          </div>
          {/* Side panel */}
          <div className="w-72 bg-[#0f0f16] border-l border-[#1a1a2e] flex flex-col shrink-0">
            <div className="flex border-b border-[#1a1a2e]">
              {[{ id: 'map', icon: TrendingUp, label: 'Мир' },{ id: 'inventory', icon: Package, label: 'Инв' },{ id: 'quests', icon: ScrollText, label: 'Квесты' },{ id: 'build', icon: Hammer, label: 'Стройка' }].map(({ id, icon: Icon, label }) => (
                <button key={id} onClick={() => setActiveTab(id as any)} className={`flex-1 py-2 flex flex-col items-center gap-0.5 text-[10px] font-mono ${activeTab === id ? 'text-blue-400 border-b-2 border-blue-500' : 'text-zinc-500'}`}><Icon size={14} />{label}</button>))}
            </div>
            <div className="flex-1 overflow-y-auto p-3">
              {activeTab === 'map' && (
                <div className="space-y-2">
                  <h3 className="font-mono text-xs text-blue-400">NPC ({npcs.length})</h3>
                  {npcs.filter(n => Math.abs(n.x - playerPos.x) < 8 && Math.abs(n.y - playerPos.y) < 8).map(n => (
                    <div key={n.id} className="card p-2.5 flex items-center gap-2">
                      <div className="w-8 h-8 rounded bg-blue-600/20 flex items-center justify-center font-mono text-xs text-blue-400">{n.name[0]}</div>
                      <div><p className="font-mono text-xs text-zinc-300">{n.name}</p><p className="text-[9px] text-zinc-500">{n.personality} · {n.type}{n.is_unique && ' ⭐'}</p></div>
                    </div>
                  ))}
                  <h3 className="font-mono text-xs text-blue-400 mt-3">Здания ({buildings.length})</h3>
                  {buildings.filter(b => Math.abs(b.tile_x - playerPos.x) < 10 && Math.abs(b.tile_y - playerPos.y) < 10).map(b => (
                    <div key={b.id} className="card p-2.5"><p className="font-mono text-xs text-zinc-300">{b.name}</p><p className="text-[9px] text-zinc-500">{b.building_type} · HP {b.health}</p></div>
                  ))}
                </div>
              )}
              {activeTab === 'inventory' && (
                <div className="space-y-1.5">
                  <h3 className="font-mono text-xs text-blue-400 mb-2">Инвентарь ({inventory.reduce((s,i)=>s+i.quantity,0)})</h3>
                  {inventory.map(i => <div key={i.slot} className="flex justify-between card p-2"><span className="font-mono text-xs text-zinc-300 capitalize">{i.item_type}</span><span className="font-mono text-xs text-blue-400">x{i.quantity}</span></div>)}
                </div>
              )}
              {activeTab === 'quests' && (
                <div className="space-y-2">
                  <h3 className="font-mono text-xs text-blue-400">Квесты ({quests.length})</h3>
                  {quests.map(q => <div key={q.id} className="card p-2.5"><p className="font-mono text-xs text-zinc-300">{q.title}</p><p className="text-[9px] text-zinc-500 mt-0.5">{q.description}</p></div>)}
                </div>
              )}
              {activeTab === 'build' && (
                <div className="space-y-2">
                  <h3 className="font-mono text-xs text-blue-400">Строительство</h3>
                  <div className="grid grid-cols-2 gap-1.5">
                    {[{ id:'house',l:'🏠 Дом' },{ id:'workshop',l:'🔧 Мастерская' },{ id:'farm',l:'🌾 Ферма' },{ id:'mine',l:'⛏ Шахта' },{ id:'temple',l:'⛪ Храм' },{ id:'wall',l:'🧱 Стена' }].map(({ id,l }) => (
                      <button key={id} onClick={() => { setSelectedBuilding(id); setBuildingMode(true); }} className={`p-2 rounded-lg font-mono text-[10px] ${selectedBuilding===id&&buildingMode?'bg-blue-600/20 border border-blue-500 text-blue-400':'bg-[#1a1a2e] text-zinc-400 hover:text-zinc-200'}`}>{l}</button>))}
                  </div>
                  {buildingMode && <div className="card p-2.5 mt-2"><p className="font-mono text-[10px] text-blue-400">Кликни на тайл</p><button onClick={()=>setBuildingMode(false)} className="btn-secondary text-[10px] py-1 w-full mt-1">Отмена</button></div>}
                </div>
              )}
            </div>
          </div>
        </div>
    </div>
  );
}
