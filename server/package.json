    "@types/jsonwebtoken": "^9.0.7",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.5.0",
    "@types/pg": "^8.20.0",
    "@types/pino": "^7.0.4",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^10.0.0",
    "@vitest/coverage-v8": "^4.1.7",
    "supertest": "^7.2.2",
    "tsx": "^4.19.0",
