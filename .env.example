# Demiurge — переменные окружения (пример)
# Скопируй этот файл в .env и заполни реальными значениями

# Сервер
PORT=3001
NODE_ENV=development
JWT_SECRET=generate-a-random-64-char-string
JWT_REFRESH_SECRET=generate-another-random-64-char-string
JWT_GUEST_SECRET=generate-another-random-64-char-string
SESSION_SECRET=generate-another-random-64-char-string

# PostgreSQL
DB_USER=demiurge
DB_PASSWORD=CHANGE_ME
DB_NAME=demiurge
DB_PORT=5432
DATABASE_URL=postgresql://demiurge:CHANGE_ME@localhost:5432/demiurge

# Redis
REDIS_PASSWORD=CHANGE_ME
REDIS_PORT=6379
REDIS_URL=redis://:CHANGE_ME@localhost:6379

# RouterAI (нейросеть) — получи ключ на https://routerai.ru
ROUTERAI_API_KEY=sk-your-api-key
ROUTERAI_BASE_URL=https://routerai.ru/api/v1

# ЮKassa (платежи) — получи ключи в личном кабинете
YUKASSA_SHOP_ID=your_shop_id
YUKASSA_SECRET_KEY=your_secret_key

# CORS — домены фронтенда через запятую
CORS_ORIGINS=http://localhost:5173

# Клиент (Vite)
VITE_API_URL=http://localhost:3001
VITE_WS_URL=http://localhost:3001
